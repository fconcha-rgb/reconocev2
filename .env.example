# Copia estas variables en Vercel (Settings > Environment Variables).
# Para desarrollo local, cópialas a un archivo .env.local (nunca lo subas a Git).

# --- Supabase (Dashboard > Project Settings > API) ---
# Pública, se expone al navegador.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Pública (anon key): diseñada para exponerse; RLS protege los datos.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_ejemplo
# SECRETA. Solo en servidor (sin prefijo NEXT_PUBLIC_). Bypassa RLS.
# REQUERIDA: la usa el panel admin para crear usuarios y restablecer
# contraseñas sin enviar ningún correo.
SUPABASE_SERVICE_ROLE_KEY=eyJ_ejemplo_secreta
