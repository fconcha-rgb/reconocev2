# Copia este archivo a .env.local (desarrollo) y configura las mismas
# variables en Vercel para preview/production. Nunca subas .env.local a Git.

# --- Supabase (obtener en Supabase Dashboard > Project Settings > API) ---
# Pública, se expone al navegador.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Pública (anon key), diseñada para exponerse al navegador; RLS la protege.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_ejemplo_ficticio
# SECRETA. Solo en servidor (Vercel env var, nunca NEXT_PUBLIC_). Bypassa RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ_ejemplo_ficticio_secreta

# --- App ---
# Pública. URL pública del despliegue (usada para redirect URLs de auth).
NEXT_PUBLIC_APP_URL=https://sell-in-reconoce.vercel.app
# Pública (controla si se muestra el formulario de email+password en /login).
# En Production SIEMPRE debe ser "false" — el login real de producción es
# Microsoft Entra ID. No es secreta porque solo afecta qué se muestra en UI;
# la seguridad real de todos modos depende de Supabase Auth y RLS.
NEXT_PUBLIC_ENABLE_DEV_AUTH=true

# --- Microsoft Entra ID (producción) ---
# Secreta. Se obtiene al registrar la app en Entra ID > App registrations.
AZURE_AD_CLIENT_ID=
# Secreta.
AZURE_AD_CLIENT_SECRET=
# Secreta. Tenant ID de la organización Falabella.
AZURE_AD_TENANT_ID=

# --- Teams (opcional, desacoplado) ---
# Secreta. URL del webhook/workflow de Teams. Si está vacía, el adapter
# queda en modo mock local y no envía nada.
TEAMS_WEBHOOK_URL=

# --- Zona horaria de jobs ---
CRON_TIMEZONE=America/Santiago
